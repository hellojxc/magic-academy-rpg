{
  "name": "magic-academy-rpg",
  "version": "0.1.0",
  "description": "2D Magic Academy Dating RPG prototype",
  "type": "module",
  "scripts": {
    "assets:characters": "node scripts/generate-character-glb.mjs",
    "assets:characters:blender": "node scripts/run-blender-character-template.mjs",
    "assets:characters:blender:preview": "node scripts/run-blender-character-preview.mjs",
    "assets:characters:inspect": "node scripts/character-pipeline/inspect-glb.mjs",
    "assets:characters:audit": "node scripts/character-pipeline/audit-runtime-character.mjs",
    "assets:characters:review": "node scripts/character-pipeline/write-character-review.mjs",
    "assets:characters:source:export": "node scripts/character-pipeline/export-source-character.mjs",
    "assets:characters:candidate:prepare": "node scripts/character-pipeline/prepare-ai-candidate-job.mjs",
    "assets:characters:candidate:audit": "node scripts/character-pipeline/audit-character-candidate.mjs",
    "assets:characters:candidate:register": "node scripts/character-pipeline/register-ai-candidate.mjs",
    "assets:characters:commercial:promote": "node scripts/character-pipeline/promote-commercial-character.mjs",
    "assets:characters:reference:prepare": "node scripts/character-pipeline/prepare-reference-sheet-job.mjs",
    "assets:characters:reference:register": "node scripts/character-pipeline/register-reference-image.mjs",
    "assets:characters:story:import": "node scripts/character-pipeline/generate-story-character-briefs.mjs",
    "assets:characters:npc:template-specs": "node scripts/character-pipeline/generate-npc-template-specs.mjs",
    "assets:characters:story:runtime-specs": "node scripts/character-pipeline/generate-story-character-runtime-specs.mjs",
    "assets:world": "npm run assets:world:materials && npm run assets:world:chunks && npm run assets:world:optimize && npm run assets:world:report",
    "assets:world:blender": "blender assets/world/magic-academy.blend --background --python scripts/blender/export_academy_scene_chunks.py",
    "assets:world:materials": "node scripts/world-pipeline/generate-world-materials.mjs",
    "assets:world:chunks": "node scripts/world-pipeline/generate-world-chunks.mjs",
    "assets:world:optimize": "node scripts/world-pipeline/optimize-world-assets.mjs",
    "assets:world:vendor": "node scripts/world-pipeline/sync-vendor-world-assets.mjs",
    "assets:world:report": "node scripts/world-pipeline/report-world-assets.mjs",
    "qa:r3f": "node scripts/world-pipeline/verify-r3f-render.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:update": "scripts/update-preview.sh"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "ecctrl": "^2.0.0",
    "postprocessing": "^6.39.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "gltfjsx": "^6.5.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
